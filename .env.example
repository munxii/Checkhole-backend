MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
# Must be at least 32 bytes (256 bits) for HS256
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters
# Shared secret for the LoRa gateway (Raspberry Pi). Sent as X-Gateway-Key header.
GATEWAY_API_KEY=replace-with-a-long-random-string
